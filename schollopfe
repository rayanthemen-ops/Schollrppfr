		frame.Size = UDim2.new(0,0,0,0)
		TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0,500,0,320)}):Play()
		blurToggle(true)
	end

	local function closeUI()
		if not opened then return end
		opened = false
		-- CORRECTION SYNTAXE ICI (0.2 au lieu de 0,2)
		local t = TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0,0,0,0)})
		t:Play()
		t.Completed:Connect(function() if not opened then frame.Visible = false end end)
		blurToggle(false)
	end

	openBtn.MouseButton1Click:Connect(function() if opened then closeUI() else open() end end)
	close.MouseButton1Click:Connect(closeUI)
	open()
end

