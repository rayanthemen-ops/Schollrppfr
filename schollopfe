				hl.Name = "SF_ESP_Hl"
				hl.FillColor = boxColor
				hl.OutlineColor = boxColor
				hl.FillTransparency = 0.6
				hl.OutlineTransparency = 0.1
				hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
				hl.Parent = character

				local bgui = Instance.new("BillboardGui")
				bgui.Name = "SF_ESP_Tag"
