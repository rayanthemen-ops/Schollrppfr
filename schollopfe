	local function checkIsStaff(targetPlayer)
		if targetPlayer.Team then
			local tName = string.lower(targetPlayer.Team.Name)
			if string.find(tName, "staff") or string.find(tName, "admin") or string.find(tName, "mod") or string.find(tName, "gérant") or string.find(tName, "créateur") or string.find(tName, "support") then
				return true, targetPlayer.Team.Name
			end
		end
		if game.CreatorId and game.CreatorType == Enum.CreatorType.Group then
			local success, role = pcall(function() return targetPlayer:GetRoleInGroup(game.CreatorId) end)
			if success and role then
				local rName = string.lower(role)
				if string.find(rName, "staff") or string.find(rName, "admin") or string.find(rName, "mod") or string.find(rName, "gérant") or string.find(rName, "créateur") or string.find(rName, "dev") or string.find(rName, "helper") then
					return true, role
				end
			end
		end
		local items = {}
		if targetPlayer:FindFirstChild("Backpack") then
			for _, tool in pairs(targetPlayer.Backpack:GetChildren()) do table.insert(items, string.lower(tool.Name)) end
		end
		if targetPlayer.Character then
			for _, tool in pairs(targetPlayer.Character:GetChildren()) do if tool:IsA("Tool") then table.insert(items, string.lower(tool.Name)) end end
		end
		for _, itemName in pairs(items) do
			if string.find(itemName, "mod") or string.find(itemName, "ban") or string.find(itemName, "panel") or string.find(itemName, "staff") then
				return true, "Staff (via Mod Tools)"
			end
		end
		return false, nil
	end

