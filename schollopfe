-- VARIABLES GLOBALES
local camera = workspace.CurrentCamera
local UserInputService = game:GetService("UserInputService")
local freecamActive = false
local freecamConn = nil
local camSpeed = 1.5

-- OPTION VITESSE
createPlayerOption("🚀 Vitesse Freecam", 1.5, function(val)
    camSpeed = val
end)

-- FONCTION DE DÉPLACEMENT ET ROTATION
local function updateFreecam(dt)
    if not freecamActive then return end
    
    -- On force les paramètres de caméra
    if camera.CameraType ~= Enum.CameraType.Scriptable then camera.CameraType = Enum.CameraType.Scriptable end
    if camera.CameraSubject ~= nil then camera.CameraSubject = nil end
    
    -- Mouvement (Joystick)
    local hum = getHum()
    local moveDir = (hum and hum.MoveDirection) or Vector3.new(0,0,0)
    
    if moveDir.Magnitude > 0 then
        local look = camera.CFrame.LookVector
        local right = camera.CFrame.RightVector
        local move = (right * moveDir.X) + (look * -moveDir.Z)
        camera.CFrame = camera.CFrame + (move * (camSpeed * 3))
    end
    
    -- Rotation (Glisser le doigt)
    local delta = UserInputService:GetMouseDelta()
    if delta.Magnitude > 0 then
        local pitch = -delta.Y * 0.005 
        local yaw = -delta.X * 0.005
        camera.CFrame = camera.CFrame * CFrame.fromEulerAnglesYXZ(pitch, yaw, 0)
    end
end

-- TOGGLE
createPlayerToggle("🎥 Bypass Freecam", function(enabled)
    freecamActive = enabled
    local root = getRoot()
    local hum = getHum()
    
    if enabled then
        if root then root.Anchored = true; root.CanCollide = false end
        if hum then hum.PlatformStand = true end
        
        -- On connecte la fonction ici
        freecamConn = RunService.RenderStepped:Connect(updateFreecam)
    else
        -- On déconnecte proprement
        if freecamConn then freecamConn:Disconnect(); freecamConn = nil end
        if root then root.Anchored = false; root.CanCollide = true end
        if hum then hum.PlatformStand = false end
        
        camera.CameraType = Enum.CameraType.Custom
        if hum then camera.CameraSubject = hum end
    end
end)




