				label.Parent = bgui

				local connection
				connection = RunService.RenderStepped:Connect(function()
					if not character.Parent or not Player.Character then
						connection:Disconnect()
						return
					end
					local myRoot = getRoot(Player.Character)
					local targetRoot = getRoot(character)
					if myRoot and targetRoot then
						local distance = math.floor((myRoot.Position - targetRoot.Position).Magnitude)
						label.Text = string.format("👤 %s\n🏷️ %s\n📍 [%d m]", displayName, displayRole, distance)
					end
				end)
			end

			if targetPlayer.Character then task.spawn(setupCharacterESP, targetPlayer.Character) end
		end
