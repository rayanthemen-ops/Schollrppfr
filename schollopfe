	local function createPage(name)
		local p = Instance.new("Frame")
		p.Size = UDim2.new(1,0,1,0)
		p.BackgroundTransparency = 1
		p.Visible = false
		p.Parent = content
		UI.Pages[name] = p
		return p
	end

	local function show(name)
		if UI.CurrentTab == name then return end
		UI.CurrentTab = name

		for _,p in pairs(UI.Pages) do p.Visible = false end
		if UI.Pages[name] then UI.Pages[name].Visible = true end

		for _,b in pairs(UI.Buttons) do b.BackgroundColor3 = Theme.TabUnselected end
		if UI.Buttons[name] then UI.Buttons[name].BackgroundColor3 = Theme.Accent end
	end

