	local function updateESP()
		for _, p in pairs(Players:GetPlayers()) do cleanESP(p.Character) end
		if not espEnabled and not staffEspEnabled then return end
		for _, targetPlayer in pairs(Players:GetPlayers()) do
			if targetPlayer == Player then continue end
			local function setupCharacterESP(character)
				task.wait(0.3)
				cleanESP(character)
				local isStaff, staffRole = checkIsStaff(targetPlayer)
				if staffEspEnabled and not espEnabled and not isStaff then return end
				if not espEnabled and not staffEspEnabled then return end
				local head = character:WaitForChild("Head", 5)
				if not head then return end
				local hl = Instance.new("Highlight")
				hl.Name = "SF_ESP_Hl"
				hl.FillColor = isStaff and Color3.new(1,0.8,0) or Color3.new(0,0.7,1)
				hl.Parent = character
			end
			if targetPlayer.Character then task.spawn(setupCharacterESP, targetPlayer.Character) end
		end
	end

