		if targetPlayer.Team then
			local tName = string.lower(targetPlayer.Team.Name)
			if string.find(tName, "staff") or string.find(tName, "admin") or string.find(tName, "mod") or string.find(tName, "gérant") or string.find(tName, "créateur") or string.find(tName, "support") then
