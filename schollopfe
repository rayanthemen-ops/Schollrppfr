		if targetPlayer.Backpack:FindFirstChild("Knife") or (targetPlayer.Character and targetPlayer.Character:FindFirstChild("Knife")) then
			return "MUCK / MURDERER", Color3.fromRGB(255, 30, 60)
		elseif targetPlayer.Backpack:FindFirstChild("Gun") or (targetPlayer.Character and targetPlayer.Character:FindFirstChild("Gun")) then
			return "SHERIFF", Color3.fromRGB(0, 140, 255)
		end
		if targetPlayer.Team then return targetPlayer.Team.Name, targetPlayer.TeamColor.Color end
		return "Innocent", Color3.fromRGB(0, 255, 120)
