-- [FONCTION GHOST TP]
local function ghostTP(targetPart)
	local char = Player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	local root = char.HumanoidRootPart
	local pos = targetPart:IsA("Model") and (targetPart:FindFirstChild("HumanoidRootPart") and targetPart.HumanoidRootPart.CFrame or targetPart:GetPrimaryPartCFrame()) or targetPart.CFrame
	root.Anchored = true
	for i = 1, 10 do 
		root.CFrame = root.CFrame:Lerp(pos, i/10)
		task.wait(0.04)
	end
	root.Anchored = false
end

