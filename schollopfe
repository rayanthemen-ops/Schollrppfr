-- Amélioration : Le changement de thème met aussi à jour l'onglet actif instantanément
local function applyTheme(color)
	Theme.Accent = color
	if UI.openBtn then UI.openBtn.BackgroundColor3 = color end
	if UI.stroke then
		TweenService:Create(UI.stroke, TweenInfo.new(0.3), {Color = color}):Play()
	end
	if UI.CurrentTab and UI.Buttons[UI.CurrentTab] then
		UI.Buttons[UI.CurrentTab].BackgroundColor3 = color
	end
end

