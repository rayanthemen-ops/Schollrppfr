local function themeButton(txt,color,y)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(0,240,0,45)
	b.Position = UDim2.new(0,20,0,y)
	b.Text = txt
	b.Parent = themePage
	Instance.new("UICorner", b)

	b.MouseButton1Click:Connect(function()
		clickSound()

		applyTheme({
			Bg = color:Lerp(Color3.fromRGB(10,10,15),0.7),
			Dark = color:Lerp(Color3.fromRGB(0,0,0),0.4),
			Accent = color
		})
	end)
end

