---------------------------------------------------
-- OPEN / CLOSE + SF ANIMATION FIX
---------------------------------------------------
local closed = false

local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(0,40,0,40)
toggle.Position = UDim2.new(1,-45,0,7)
toggle.Text = "X"
toggle.BackgroundColor3 = Color3.fromRGB(200,60,60)
toggle.Parent = topBar
Instance.new("UICorner", toggle)

local function openUI()
	closed = false
	frame.Visible = true
	setBlur(true)

	frame.Size = UDim2.new(0,0,0,0)

	TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.new(0,560,0,650)
	}):Play()
end

local function closeUI()
	closed = true
	setBlur(false)

	local t = TweenService:Create(frame, TweenInfo.new(0.25), {
		Size = UDim2.new(0,0,0,0)
	})

	t:Play()
	t.Completed:Connect(function()
		frame.Visible = false
	end)

	toggle.Parent = gui
	toggle.Size = UDim2.new(0,60,0,60)
	toggle.Position = UDim2.new(0,20,0,200)
	toggle.Text = "SF"
	toggle.BackgroundColor3 = Color3.fromRGB(0,200,120)
end

toggle.MouseButton1Click:Connect(function()
	if not closed then
		closeUI()
	else
		toggle.Parent = topBar
		toggle.Size = UDim2.new(0,40,0,40)
		toggle.Position = UDim2.new(1,-45,0,7)
		toggle.Text = "X"
		toggle.BackgroundColor3 = Color3.fromRGB(200,60,60)

		openUI()
	end
end)

